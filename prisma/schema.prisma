generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model User {
  clerkId                  String            @unique
  email                    String            @unique
  replyToEmail             String?           @unique
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  firstName                String?
  lastName                 String?
  stripeCustomerId         String?           @unique
  stripePriceId            String?
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?
  id                       Int               @id @default(autoincrement())
  role                     UserRole          @default(user)
  accountType              AccountType       @default(standard)
  aiDraftCredits           Int               @default(5)
  aiTestCredits            Int               @default(2)
  murmurEmail              String?           @unique
  customDomain             String?
  draftCredits             Float             @default(0)
  sendingCredits           Float             @default(0)
  verificationCredits      Float             @default(0)
  lastCreditUpdate         DateTime?
  stripePromoCode          String?
  campaigns                Campaign[]
  contacts                 Contact[]
  contactLists             ContactList[]
  emails                   Email[]
  identities               Identity[]
  signatures               Signature[]
  userContactLists         UserContactList[]
  inboundEmails            InboundEmail[]
  mediaAssets              MediaAsset[]
  venue                    Venue?
  events                   Event[]
}

model ContactList {
  name      String     @unique(map: "ContactList_category_key")
  count     Int?       @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  id        Int        @id @default(autoincrement())
  userId    String?
  title     String     @default("Untitled Contact List")
  contacts  Contact[]
  user      User?      @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  campaigns Campaign[] @relation("CampaignToContactList")

  @@index([userId])
}

model UserContactList {
  id        Int        @id @default(autoincrement())
  name      String
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  campaigns Campaign[] @relation("CampaignToUserContactList")
  contacts  Contact[]  @relation("ContactToUserContactList")

  @@index([userId])
}

model Contact {
  venueId                  Int?                    @unique
  email                    String
  company                  String?
  country                  String?
  createdAt                DateTime                @default(now())
  phone                    String?
  state                    String?
  updatedAt                DateTime                @updatedAt
  website                  String?
  id                       Int                     @id @default(autoincrement())
  contactListId            Int?
  address                  String?
  apolloPersonId           String?                 @unique
  city                     String?
  emailValidatedAt         DateTime?
  emailValidationStatus    EmailVerificationStatus @default(unknown)
  emailValidationSubStatus String?
  firstName                String?
  headline                 String?
  lastName                 String?
  linkedInUrl              String?
  photoUrl                 String?
  title                    String?
  metadata                 String?
  userId                   String?
  isPrivate                Boolean                 @default(false)
  hasVectorEmbedding       Boolean                 @default(false)
  userContactListCount     Int                     @default(0)
  manualDeselections       Int                     @default(0)
  companyFoundedYear       String?
  companyIndustry          String?
  companyKeywords          String[]
  companyLinkedInUrl       String?
  companyPostalCode        String?
  companyTechStack         String[]
  companyType              String?
  lastResearchedDate       DateTime?
  latitude                 Float?
  longitude                Float?
  contactList              ContactList?            @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  user                     User?                   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  Email                    Email[]
  campaigns                Campaign[]              @relation("CampaignToContact")
  userContactLists         UserContactList[]       @relation("ContactToUserContactList")
  inboundEmails            InboundEmail[]

  @@unique([email, contactListId])
  @@index([contactListId])
  @@index([userId])
  @@index([latitude, longitude])
  @@index([longitude, latitude])
}

model Email {
  subject      String
  message      String
  status       EmailStatus    @default(draft)
  reviewStatus ReviewStatus?
  sentAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userId       String
  id           Int            @id @default(autoincrement())
  campaignId   Int
  contactId    Int
  campaign     Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  replies      InboundEmail[] @relation("EmailReplies")

  @@index([campaignId])
}

model Campaign {
  name                  String
  userId                String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  id                    Int                    @id @default(autoincrement())
  fullAiPrompt          String?                @map("message")
  subject               String?
  testMessage           String?
  testSubject           String?
  senderEmail           String?
  senderName            String?
  status                Status                 @default(active)
  signatureId           Int?
  font                  String                 @default("Arial")
  identityId            Int?
  draftingMode          DraftingMode           @default(hybrid)
  draftingTone          DraftingTone           @default(normal)
  handwrittenPrompt     String?
  hybridPrompt          String?
  isAiSubject           Boolean                @default(true)
  paragraphs            Int?                   @default(0)
  hybridBlockPrompts    Json?                  @default("[{\"id\": \"full_automated\", \"type\": \"full_automated\", \"value\": \"\"}]")
  hybridAvailableBlocks HybridBlock[]          @default([full_automated, introduction, research, action, text])
  identity              Identity?              @relation(fields: [identityId], references: [id])
  signature             Signature?             @relation(fields: [signatureId], references: [id])
  user                  User                   @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  emails                Email[]
  contacts              Contact[]              @relation("CampaignToContact")
  contactLists          ContactList[]          @relation("CampaignToContactList")
  userContactLists      UserContactList[]      @relation("CampaignToUserContactList")
  contactEvents         CampaignContactEvent[]
  inboundEmails         InboundEmail[]

  @@index([userId])
}

model CampaignContactEvent {
  id            Int      @id @default(autoincrement())
  campaignId    Int
  createdAt     DateTime @default(now())
  addedCount    Int
  totalContacts Int
  source        String?
  metadata      Json?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt])
}

model Identity {
  id        Int        @id @default(autoincrement())
  name      String
  website   String?
  email     String
  genre     String?
  area      String?
  bandName  String?
  bio       String?
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaigns Campaign[]
  user      User       @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@index([userId])
}

model Venue {
  id           Int      @id @default(autoincrement())
  userId       String   @unique
  venueName    String
  address      String?
  city         String?
  state        String?
  latitude     Float?
  longitude    Float?
  businessType String?
  hours        Json?
  capacityMin  Int?
  capacityMax  Int?
  genres       String[]
  payRange     String?
  payMin       Int?
  payMax       Int?
  sound        String?
  description  String?
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
}

model Event {
  id        Int       @id @default(autoincrement())
  userId    String // clerkId of the venue account that created the event
  name      String
  address   String?
  placeId   String?
  latitude  Float?
  longitude Float?
  size      String? // free text: "Solo" | "Duo" | "Full Band" | "Other" | anything
  genres    String[]
  whenLabel String? // faithful display label, e.g. "June 15th 2026"
  startTime String? // raw "HH:MM" as entered
  endTime   String? // raw "HH:MM" as entered
  startsAt  DateTime? // derived UTC instant (picked date + startTime, browser-local)
  endsAt    DateTime? // derived UTC instant (picked date + endTime, browser-local)
  pay       String? // free text, e.g. "$150-500"
  details   String?
  isActive  Boolean   @default(true) // soft-delete flag: venue "deletes" hide the event, the row stays
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@index([userId])
  @@index([startsAt])
}

model Signature {
  id        Int        @id @default(autoincrement())
  content   String     @default("")
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  name      String
  campaigns Campaign[]
  user      User       @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@index([userId])
}

model MediaAsset {
  id          Int         @id @default(autoincrement())
  userId      String
  kind        MediaKind
  context     String
  key         String
  posterKey   String?
  filename    String
  contentType String
  sizeBytes   Int?
  durationSec Float?
  status      MediaStatus @default(uploading)
  position    Int         @default(0)
  sourceType  MediaSource @default(upload)
  embedUrl    String?
  shareId     String      @unique @default(cuid())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@index([userId, context])
}

model EmailVerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([email, code])
  @@index([email])
  @@index([expiresAt])
}

model ContactVerificationRequest {
  id                        Int                              @id @default(autoincrement())
  fileId                    String                           @unique
  estimatedTimeOfCompletion DateTime
  limit                     Int?
  notVerifiedSince          DateTime?
  onlyUnverified            Boolean?
  query                     String?
  status                    ContactVerificationRequestStatus @default(processing)
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
}

model ApolloQuery {
  id                  Int        @id @default(autoincrement())
  query               String
  apolloQuery         Json
  maxPage             Int
  pageLastFetched     Int
  pageFetchTimeStamps DateTime[]
}

model Lead {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InboundEmail {
  id                Int       @id @default(autoincrement())
  sender            String
  senderName        String?
  recipient         String
  to                String?
  from              String?
  subject           String?
  date              String?
  mimeVersion       String?
  inReplyTo         String?
  userAgent         String?
  references        String?
  contentType       String?
  messageHeaders    Json?
  received          String?
  messageId         String    @unique
  bodyPlain         String?
  bodyHtml          String?
  strippedText      String?
  strippedHtml      String?
  strippedSignature String?
  attachments       Json?
  attachmentCount   Int?
  contentIdMap      Json?
  mailgunVariables  Json?
  token             String?
  timestamp         Int?
  signature         String?
  userId            String?
  user              User?     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  contactId         Int?
  contact           Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  originalEmailId   Int?
  originalEmail     Email?    @relation("EmailReplies", fields: [originalEmailId], references: [id], onDelete: SetNull)
  campaignId        Int?
  campaign          Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  receivedAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([recipient])
  @@index([sender])
  @@index([contactId])
  @@index([campaignId])
  @@index([receivedAt])
  @@index([messageId])
  @@index([inReplyTo])
}

enum EmailStatus {
  draft
  scheduled
  sent
  failed
}

enum ReviewStatus {
  approved
  rejected
}

enum EmailVerificationStatus {
  valid
  invalid
  catch_all
  spamtrap
  abuse
  do_not_mail
  unknown
}

enum HybridBlock {
  introduction
  research
  action
  text
  full_automated
}

enum ContactVerificationRequestStatus {
  processing
  completed
  failed
}

enum AiModel {
  sonar
  sonar_pro @map("sonar-pro")
}

enum UserRole {
  user
  admin
}

enum AccountType {
  standard
  venue
}

enum Status {
  active
  deleted
  archived
}

enum DraftingMode {
  ai
  hybrid
  handwritten
}

enum DraftingTone {
  normal
  explanatory
  formal
  concise
  casual
}

enum MediaKind {
  video
  audio
  image
}

enum MediaStatus {
  uploading
  ready
  failed
}

enum MediaSource {
  upload
  youtube
}

// ─────────────────────────────────────────────────────────────────────────────
// Internal messaging (venue ↔ standard-user direct messages).
// STRICTLY ADDITIVE: new models + enum only. Links to existing tables
// (standardUserId, venueId, emailId, campaignId) are plain SCALAR columns with NO
// @relation to existing models — resolved by explicit lookups in code — so no
// existing model is modified and the migration references no existing table. The
// only relation is Conversation ↔ Message (both new).
// ─────────────────────────────────────────────────────────────────────────────

enum MessageSender {
  standard
  venue
}

model Conversation {
  id                 Int       @id @default(autoincrement())
  standardUserId     String // clerkId of the standard (artist) user
  venueId            Int // Venue.id (== Contact.venueId)
  standardLastReadAt DateTime?
  venueLastReadAt    DateTime?
  lastMessageAt      DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  messages Message[]

  @@unique([standardUserId, venueId])
  @@index([standardUserId, lastMessageAt])
  @@index([venueId, lastMessageAt])
}

model Message {
  id                  Int           @id @default(autoincrement())
  conversationId      Int
  sender              MessageSender
  senderClerkId       String
  body                String
  isHtml              Boolean       @default(false)
  emailId             Int? // provenance of the diverted first message (scalar, no FK)
  applicationId       Int? // provenance of an application-seeded message (scalar, no FK)
  campaignId          Int? // provenance of the originating campaign (scalar, no FK)
  // Thread partition within the conversation: messages exchanged in the context of
  // a specific EventApplication carry its id; null = the general/cold-outreach
  // thread (scalar, no FK). Seeded summaries carry both this and applicationId.
  threadApplicationId Int?
  // Booking-request delivery: set on the Message that carries a BookingRequest so
  // it rides the thread like any reply (scalar, no FK; additive column).
  bookingRequestId    Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([emailId])
  @@unique([applicationId])
  @@index([conversationId, id])
  @@index([conversationId, threadApplicationId, id])
}

// Per-side read watermarks for one application thread (the per-pair Conversation
// watermarks keep governing the general thread). STRICTLY ADDITIVE: new model with
// a scalar applicationId (no FK), mirroring the EventApplication precedent.
model ApplicationReadState {
  id                 Int       @id @default(autoincrement())
  applicationId      Int       @unique // EventApplication.id (scalar, no FK)
  venueLastReadAt    DateTime?
  standardLastReadAt DateTime? // the applicant's watermark for this thread
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

enum BookingRequestStatus {
  pending
  confirmed
  canceled
}

// A venue's "Request to book {artist}" handshake inside one conversation thread.
// STRICTLY ADDITIVE: new model with scalar ids only (no FK relations), mirroring
// the EventApplication / ApplicationReadState precedent. Participant ids are
// denormalized at creation so cancel/confirm authorize without joins. The request
// is delivered as an in-thread Message (Message.bookingRequestId) so previews,
// unread counts, and the venue inbound projection work unchanged.
model BookingRequest {
  id                  Int                  @id @default(autoincrement())
  conversationId      Int // Conversation.id (scalar, no FK)
  threadApplicationId Int? // EventApplication.id; null = the general/cold-outreach thread (scalar, no FK)
  eventId             Int? // Event.id, denormalized from the application at request time (scalar, no FK)
  venueUserId         String // venue owner clerkId (== Venue.userId at request time)
  standardUserId      String // artist clerkId (== Conversation.standardUserId)
  venueId             Int // Venue.id (== Conversation.venueId)
  status              BookingRequestStatus @default(pending)
  // 'YYYY-MM-DD' local-date key, matching CalendarEntry.date; null until the artist
  // confirms (the server never derives a calendar day from the event's UTC instant).
  date                String?
  requestedAt         DateTime             @default(now())
  confirmedAt         DateTime?
  canceledAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([conversationId, threadApplicationId, status])
  @@index([eventId, status])
  @@index([standardUserId, status])
  @@index([venueUserId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Event applications (standard-user → venue Event).
// STRICTLY ADDITIVE: new models + enum only. Links to existing tables (eventId,
// standardUserId, venueUserId, sourceMediaAssetId) are plain SCALAR columns with NO
// @relation to Event / User / MediaAsset — resolved by explicit lookups in code —
// so no existing model is modified and the migration references no existing table.
// The only relation is EventApplication ↔ ApplicationVideo (both new), mirroring
// the Conversation ↔ Message precedent. Submitted videos are FROZEN: each upload is
// copied to an application-scoped R2 key at apply time, so a venue's record survives
// the artist later deleting the source video from their profile pool.
// ─────────────────────────────────────────────────────────────────────────────

enum ApplicationStatus {
  submitted
  withdrawn
}

model EventApplication {
  id             Int    @id @default(autoincrement())
  eventId        Int // Event.id (the opportunity). Scalar, no FK.
  standardUserId String // clerkId of the applying standard user. Scalar, no FK.
  venueUserId    String // == Event.userId (venue owner clerkId), denormalized at apply time.

  // Point-in-time snapshot of the modal answers (seeded from Identity but freely
  // edited in the modal — so we snapshot the submitted values, not a FK).
  genre          String?
  area           String?
  performingName String?
  bio            String?

  status    ApplicationStatus @default(submitted)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  videos ApplicationVideo[]

  @@unique([eventId, standardUserId])
  @@index([eventId, createdAt])
  @@index([standardUserId, createdAt])
  @@index([venueUserId, createdAt])
}

model ApplicationVideo {
  id                 Int  @id @default(autoincrement())
  applicationId      Int
  sourceMediaAssetId Int? // provenance: profile MediaAsset it was copied from (scalar, no FK).

  // Immutable snapshot copied at apply time — independent of the artist's profile pool.
  kind        MediaKind
  sourceType  MediaSource
  key         String? // application-scoped R2 key (copied object). Null for youtube.
  posterKey   String? // application-scoped R2 key for the poster. Null for youtube.
  embedUrl    String? // youtube watch URL (sourceType = youtube; no R2 copy).
  filename    String?
  contentType String?
  durationSec Float?
  position    Int         @default(0)
  createdAt   DateTime    @default(now())

  application EventApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// Recipients who unsubscribed from a specific artist's cold outreach emails.
// STRICTLY ADDITIVE: scalar userId (clerkId), no FK relation (matches messaging models).
model EmailSuppression {
  id        Int      @id @default(autoincrement())
  email     String // recipient address, stored lowercased
  userId    String // artist's clerkId whose sends are suppressed
  reason    String   @default("unsubscribe") // 'page' | 'one_click'
  createdAt DateTime @default(now())

  @@unique([email, userId])
  @@index([email])
}

model ContactNote {
  id        Int      @id @default(autoincrement())
  userId    String // owner's clerkId; intentionally no FK
  contactId Int // Contact.id; intentionally no FK
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contactId])
  @@index([contactId])
}

model CalendarEntry {
  id               Int      @id @default(autoincrement())
  userId           String
  date             String
  personName       String   @default("")
  company          String   @default("")
  startTime        String   @default("")
  endTime          String   @default("")
  notes            String   @default("")
  address          String   @default("")
  placeId          String?
  latitude         Float?
  longitude        Float?
  drivingDuration  String?
  campaignId       Int? // Campaign.id provenance from the inbox booking flow; intentionally no FK
  contactId        Int? // Contact.id provenance; intentionally no FK
  bookingRequestId Int? // BookingRequest.id provenance for confirmed bookings; intentionally no FK
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, date])
}

// A venue user's personal 1–5 star rating of one submitted application video.
// STRICTLY ADDITIVE: scalar ids, no FK relations (ContactNote pattern).
// applicationId + standardUserId are denormalized at write time for per-
// application averages and future artist-level views. rating 0 = cleared
// (rows are never hard-deleted).
model ApplicationVideoRating {
  id             Int      @id @default(autoincrement())
  userId         String // venue owner's clerkId; intentionally no FK
  videoId        Int // ApplicationVideo.id; intentionally no FK
  applicationId  Int // EventApplication.id, denormalized
  standardUserId String // applying artist's clerkId, denormalized
  rating         Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([userId, applicationId])
  @@index([userId, standardUserId])
}

// Cached intelligent match score: how relevant one submitted application is to
// its event + venue context. STRICTLY ADDITIVE: scalar ids, no FK relations
// (ApplicationVideoRating pattern). One row per application — re-apply upserts
// the EventApplication snapshot, which changes inputHash and lazily recomputes
// on the next venue read. Fallback (non-LLM) scores are never persisted.
model ApplicationMatchScore {
  id            Int      @id @default(autoincrement())
  applicationId Int      @unique // EventApplication.id; intentionally no FK
  eventId       Int // Event.id, denormalized for per-event reads/invalidation
  venueUserId   String // venue owner clerkId, denormalized (EventApplication parity)
  score         Int // final displayed percent, 0-100
  breakdown     Json // { version, method, components, weights, caps, inferredGenre, rationale }
  inputHash     String // sha256 over canonical scoring inputs + SCORER_VERSION
  scorerVersion Int // mirrors the version baked into inputHash (analytics/cleanup)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([eventId])
}

// Intelligent async send queue: cold campaign emails are queued and trickled out
// at spread-out daytime times (<=100/sender/day, 11am-8pm ET window) instead of
// firing synchronously. STRICTLY ADDITIVE: new model + enum only; all links
// (emailId, userId, campaignId, contactId) are scalar columns with NO @relation,
// resolved by explicit lookups in code (EmailSuppression / ContactNote pattern),
// so no existing model is modified and the migration is CREATE-only.
enum SendQueueStatus {
  pending // waiting for its scheduledFor instant
  processing // a worker run has claimed it (lockedAt/lockToken set) and is sending
  sent // delivered via Mailgun; terminal
  failed // permanently failed / expired / out-of-credits; terminal
  canceled // un-queued before send (campaign archived etc.); terminal
}

model EmailSendQueue {
  id         Int    @id @default(autoincrement())
  emailId    Int    @unique // Email.id — one LIVE queue row per Email (cancel DELETEs the row)
  userId     String // sender clerkId (== Email.userId); per-day cap + claim key
  campaignId Int // Campaign.id provenance; intentionally no FK
  contactId  Int // Contact.id recipient; intentionally no FK

  status       SendQueueStatus @default(pending)
  scheduledFor DateTime // UTC instant chosen by the pure scheduler
  capDay       String // == capDayOf(scheduledFor) in senderRefTz; the per-day (100) cap bucket
  recipientTz  String          @default("America/New_York") // window tz (v1: fixed; v2: per-recipient)

  dispatchedAt          DateTime? // set IMMEDIATELY before mg.create() — splits the stuck-row sweeper
  attempts              Int       @default(0) // ONLY incremented on a real Mailgun attempt
  maxAttempts           Int       @default(5)
  capRescheduleCount    Int       @default(0) // cap/window backlog rolls (lifetime-guarded)
  creditRescheduleCount Int       @default(0) // credit-block rolls (rare) -> failed:no_credits at small N
  creditBlockedAt       DateTime? // first credit-block instant (notify-once)
  nextRetryAt           DateTime? // transient-failure backoff gate
  lockedAt              DateTime? // set when a worker claims the row
  lockToken             String? // per-run uuid; guards the terminal write
  failureReason         String?
  sentAt                DateTime?

  createdAt DateTime @default(now()) // claim FIFO tiebreak + lifetime guard
  updatedAt DateTime @updatedAt

  @@index([status, scheduledFor]) // claim scan + overdue health
  @@index([userId, capDay, status]) // per-sender-per-day cap accounting
  @@index([campaignId, status]) // cancel-on-archive
  @@index([status, lockedAt]) // stuck-row sweeper
}

// Persistent cache for LLM query-intent classifications (free-text search
// query understanding). Keyed on the normalized query remainder + prompt
// version — bumping INTENT_PROMPT_VERSION in queryUnderstanding.ts orphans
// old rows (atomic invalidation). Serverless lambdas lose in-memory LRUs on
// every cold start; this table is what makes repeat queries never re-pay the
// LLM. Deterministic-fallback intents are NEVER persisted here.
model SearchQueryIntent {
  id            Int      @id @default(autoincrement())
  queryKey      String
  promptVersion Int
  intent        Json
  model         String
  hitCount      Int      @default(0)
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime @default(now())

  @@unique([queryKey, promptVersion])
  @@index([lastUsedAt])
}
